{
  "version": 1,
  "author": "Geo Fire",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 0, "left": 0, "attrs": {} },
    { "type": "wokwi-dht22", "id": "dht1", "top": -160, "left": -220, "rotate": 270, "attrs": { "humidity": "66" } },
    { "type": "wokwi-gas-sensor", "id": "mq2", "top": -160, "left": 160, "attrs": {} },
    { "type": "wokwi-potentiometer", "id": "pot_rain", "top": 200, "left": -220, "attrs": { "label": "Rain" } },
    { "type": "wokwi-potentiometer", "id": "pot_soil", "top": 200, "left": -60, "attrs": { "label": "Soil" } },
    { "type": "wokwi-led", "id": "led1", "top": -160, "left": 360, "attrs": { "color": "red" } },
    { "type": "wokwi-resistor", "id": "r1", "top": -90, "left": 430, "rotate": 90, "attrs": { "value": "220" } },
    { "type": "wokwi-buzzer", "id": "bz1", "top": 40, "left": 380, "attrs": { "volume": "0.1" } }
  ],
  "connections": [
    ["esp:TX", "$serialMonitor:RX", "", []],
    ["esp:RX", "$serialMonitor:TX", "", []],

    ["dht1:VCC", "esp:5V", "red", ["h-40", "v-20"]],
    ["dht1:GND", "esp:GND.1", "black", ["h-20", "v-20"]],
    ["dht1:SDA", "esp:4", "green", ["v0"]],

    ["mq2:VCC", "esp:5V", "red", ["h0", "v-20"]],
    ["mq2:GND", "esp:GND.2", "black", ["h20", "v-20"]],
    ["mq2:AO", "esp:D34", "green", ["v0"]],

    ["pot_rain:VCC", "esp:3V3", "red", ["v-40", "h0"]],
    ["pot_rain:GND", "esp:GND.2", "black", ["v-20", "h0"]],
    ["pot_rain:SIG", "esp:D35", "purple", ["v0"]],

    ["pot_soil:VCC", "esp:3V3", "red", ["v-40", "h20"]],
    ["pot_soil:GND", "esp:GND.2", "black", ["v-20", "h20"]],
    ["pot_soil:SIG", "esp:D32", "orange", ["v0"]],

    ["led1:A", "esp:D2", "blue", ["h0", "v-20"]],
    ["led1:C", "r1:1", "blue", ["v0"]],
    ["r1:2", "esp:GND.1", "black", ["h0", "v20"]],

    ["bz1:2", "esp:D26", "red", ["v0"]],
    ["bz1:1", "esp:GND.3", "black", ["v0"]]
  ]
}
